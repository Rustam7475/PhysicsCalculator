# Общие настройки
APP_NAME=PhysicsCalculator
APP_VERSION=1.0.0
APP_ENVIRONMENT=development

# Настройки базы данных
DB_NAME=PhysicsCalculatorModel

# Настройки API
API_BASE_URL=https://api.example.com
API_VERSION=v1
API_TIMEOUT=30

# Настройки кэширования
CACHE_ENABLED=true
CACHE_DURATION=3600

# Настройки логирования
LOG_LEVEL=debug
LOG_FILE_PATH=logs/app.log

# Настройки безопасности
ENCRYPTION_KEY=your_encryption_key_here
SECURE_STORAGE_ENABLED=true

# Настройки локализации
DEFAULT_LANGUAGE=ru
SUPPORTED_LANGUAGES=ru,en,de,es,fr,zh

# Примечание: Скопируйте этот файл в .env и замените значения на свои 