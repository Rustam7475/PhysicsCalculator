        {
            "id": "mech_school_velocity",
            "subsectionId": "kinematics",
            "name_ru": "Средняя скорость",
            "name_en": "Average Velocity",
            "levels": [
                "school"
            ],
            "equation_latex": "v = \frac{s}{t}",
            "description_ru": "Средняя скорость при равномерном прямолинейном движении.",
            "description_en": "Average velocity in uniform linear motion. ***Примечание: Правила расчета добавлены для всех переменных, проверьте их корректность.***",
            "variables": [
                {
                    "symbol": "v",
                    "name_ru": "Скорость",
                    "name_en": "Velocity",
                    "unit_si": "м/с"
                },
                {
                    "symbol": "s",
                    "name_ru": "Путь",
                    "name_en": "Distance",
                    "unit_si": "м"
                },
                {
                    "symbol": "t",
                    "name_ru": "Время",
                    "name_en": "Time",
                    "unit_si": "с"
                }
            ],
            "calculation_rules": {
                "v": "s / t",
                "s": "v * t",
                "t": "s / v"
            }
        },
        {
            "id": "mech_school_acceleration",
            "subsectionId": "kinematics",
            "name_ru": "Ускорение",
            "name_en": "Acceleration",
            "levels": [
                "school"
            ],
            "equation_latex": "a = \frac{v - u}{t}",
            "description_ru": "Ускорение при равноускоренном движении (v - конечная, u - начальная).",
            "description_en": "Acceleration in uniformly accelerated motion. ***Примечание: Правила расчета добавлены для всех переменных, проверьте их корректность.***",
            "variables": [
                {
                    "symbol": "a",
                    "name_ru": "Ускорение",
                    "name_en": "Acceleration",
                    "unit_si": "м/с²"
                },
                {
                    "symbol": "v",
                    "name_ru": "Конеч. скорость",
                    "name_en": "Final Velocity",
                    "unit_si": "м/с"
                },
                {
                    "symbol": "u",
                    "name_ru": "Начал. скорость",
                    "name_en": "Initial Velocity",
                    "unit_si": "м/с"
                },
                {
                    "symbol": "t",
                    "name_ru": "Время",
                    "name_en": "Time",
                    "unit_si": "с"
                }
            ],
            "calculation_rules": {
                "a": "(v - u) / t",
                "v": "u + a * t",
                "u": "v - a * t",
                "t": "(v - u) / a"
            }
        },
